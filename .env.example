# Copy this file to .env.local for local dev. On Vercel, set each of these
# under Project Settings → Environment Variables.

# ─────────────── Session ───────────────
# iron-session encryption key — must be at least 32 chars. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Optional: shared secret used by the internal job runner. Falls back to
# SESSION_SECRET if not set. Recommended in production.
RUNNER_SECRET=

# ─────────────── Supabase ───────────────
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public mirrors used by the browser-side Supabase client (currently unused,
# safe to leave blank if you don't add Supabase Auth).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────── AI providers (fallback chain) ───────────────
# Order tried: Anthropic → Mistral → Groq → Gemini.
# You don't need all of them; the chain skips any that's missing.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
# CLAUDE_COPY_MODEL=claude-sonnet-4-5
# MISTRAL_MODEL=mistral-large-latest
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Per-provider wall-clock cap in ms (default 90000)
# PROVIDER_TIMEOUT_MS=90000

# ─────────────── Shopify ───────────────
# API version pinned for stability
SHOPIFY_API_VERSION=2025-01

# ─────────────── SERP (optional) ───────────────
# SerpAPI key for keyword ranking lookups. Pipeline gracefully degrades
# without it.
SERPAPI_KEY=
